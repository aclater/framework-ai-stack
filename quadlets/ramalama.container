# ~/.config/containers/systemd/ramalama.container
# Qwen3.5-35B-A3B via RamaLama ROCm container
# Managed by: systemctl --user [start|stop|restart|status] ramalama

[Unit]
Description=RamaLama Qwen3.5-35B-A3B
After=local-fs.target network-online.target
Wants=network-online.target

[Container]
Image=quay.io/ramalama/rocm:latest

# GPU passthrough — /dev/kfd (compute) + /dev/dri (render)
AddDevice=-/dev/kfd
AddDevice=-/dev/dri
SecurityLabelDisable=true

# GFX version override for AI Max+ 395; remove once ROCm ships gfx1151 support
Environment=HSA_OVERRIDE_GFX_VERSION=11.5.1
Environment=AMD_LOG_LEVEL=0
# Limit HW queues to reduce idle GPU busy-spin on gfx1151
Environment=GPU_MAX_HW_QUEUES=1
# KV cache quantization — reduces cache memory by ~50% vs f16, improving
# effective context capacity for long RAG prompts with 131072 ctx window
Environment=LLAMA_ARG_FLASH_ATTN=1
Environment=LLAMA_ARG_CACHE_TYPE_K=q8_0
Environment=LLAMA_ARG_CACHE_TYPE_V=q8_0

# Model bind-mount — RamaLama stores models under ~/.local/share/ramalama
Mount=type=bind,src=MODEL_PATH_PLACEHOLDER,target=/mnt/models/model.file,ro,Z

Exec=llama-server --model /mnt/models/model.file --host 0.0.0.0 --port 8080 --ctx-size 131072 --n-gpu-layers 999 --threads 16 --parallel 4 --jinja

ContainerName=ramalama
PublishPort=8080:8080

[Service]
Restart=on-failure
RestartSec=10s
TimeoutStartSec=180s

[Install]
WantedBy=default.target
