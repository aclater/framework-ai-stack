# ~/.config/containers/systemd/ragpipe.container
# ragpipe — searches Qdrant, reranks with cross-encoder, injects context
# Source: https://github.com/aclater/ragpipe
# Managed by: systemctl --user [start|stop|restart|status] ragpipe

[Unit]
Description=ragpipe (Qdrant search + reranker + context injection)
After=local-fs.target network-online.target qdrant.service postgres.service
Wants=network-online.target
Requires=qdrant.service postgres.service

[Container]
# Published image from ghcr.io — ONNX models + semantic router baked in
# RSS ~708 MB (raw ONNX Runtime, no fastembed/PyTorch)
Image=ghcr.io/aclater/ragpipe:main

# Writable model cache for ONNX models (persists across restarts)
Volume=ragpipe-model-cache:/home/default/.cache/ragpipe:Z

# Routes config (local file, not in repo)
Volume=%h/.config/ragpipe/routes.yaml:/etc/ragpipe/routes.yaml:ro,Z

# Run as non-root user (default in UBI Python images, UID 1001)
User=1001

Environment=MODEL_URL=http://host.containers.internal:8080
Environment=QDRANT_URL=http://host.containers.internal:6333
Environment=QDRANT_COLLECTION=documents

# Semantic router — optional, ragpipe works without RAGPIPE_ROUTES_FILE
# Create ~/.config/ragpipe/routes.yaml to enable routing (see ragpipe docs)
Environment=RAGPIPE_ROUTES_FILE=/etc/ragpipe/routes.yaml
# Set a real token in ~/.config/llm-stack/env — this is a placeholder
Environment=RAGPIPE_ADMIN_TOKEN=change-me

# Override ragpipe defaults for wider retrieval window (default: 20/5)
Environment=RAG_TOP_K=40
Environment=RERANKER_TOP_N=15

# Document store — asyncpg connection pool for hydration, LRU chunk cache
Environment=DOCSTORE_BACKEND=postgres
Environment=DOCSTORE_URL=postgresql://litellm:litellm@host.containers.internal:5432/litellm

# Model cache location (inside the writable volume)
Environment=RAGPIPE_MODEL_CACHE=/home/default/.cache/ragpipe

Network=host

ContainerName=ragpipe

# Health check
HealthCmd=python3 -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8090/health')"
HealthInterval=30s
HealthTimeout=10s
HealthRetries=3
HealthStartPeriod=120s

[Service]
Restart=on-failure
RestartSec=10s
TimeoutStartSec=300s

# Resource limits — ragpipe uses ~708 MB RSS with ONNX Runtime
MemoryMax=2G
CPUQuota=200%

[Install]
WantedBy=default.target
