# ~/.config/containers/systemd/postgres.container
# PostgreSQL for LiteLLM

[Unit]
Description=PostgreSQL for LiteLLM
After=local-fs.target

[Container]
# No semver tags available — pinned by digest (c9s stream, 2026-03-25)
Image=quay.io/sclorg/postgresql-16-c9s@sha256:1259822dd3aae7a8fed1c7aa6c99b1763bee06d32b34ed1dd72fe31eac07e336

# sclorg postgres data directory (not /var/lib/postgresql/data)
Volume=litellm-db-data.volume:/var/lib/pgsql/data:Z

# Credentials sourced from ragstack.env — never committed to the repo
EnvironmentFile=%h/.config/llm-stack/ragstack.env

Network=host

ContainerName=postgres

[Service]
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
