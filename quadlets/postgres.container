# ~/.config/containers/systemd/postgres.container
# PostgreSQL for LiteLLM

[Unit]
Description=PostgreSQL for LiteLLM
After=local-fs.target

[Container]
Image=quay.io/sclorg/postgresql-16-c9s:latest

# sclorg postgres data directory (not /var/lib/postgresql/data)
Volume=litellm-db-data.volume:/var/lib/pgsql/data:Z

# sclorg images use POSTGRESQL_* env vars (not POSTGRES_*)
Environment=POSTGRESQL_USER=litellm
Environment=POSTGRESQL_PASSWORD=litellm
Environment=POSTGRESQL_DATABASE=litellm

Network=host

ContainerName=postgres

[Service]
Restart=on-failure
RestartSec=5s

[Install]
WantedBy=default.target
