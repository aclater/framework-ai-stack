# ~/.config/containers/systemd/qdrant.container
# Qdrant vector database for RAG search
# Managed by: systemctl --user [start|stop|restart|status] qdrant

[Unit]
Description=Qdrant vector database
After=local-fs.target network-online.target
Wants=network-online.target

[Container]
Image=docker.io/qdrant/qdrant:v1.17.1

Volume=qdrant-data:/qdrant/storage:Z
# Required: Debian-based binary triggers SELinux execmem denial on Fedora 43
SecurityLabelDisable=true

PublishPort=6333:6333
ContainerName=qdrant

# No curl in the Debian-minimal image — use bash /dev/tcp
HealthCmd=bash -c 'echo -e "GET /healthz HTTP/1.0\r\n" > /dev/tcp/127.0.0.1/6333'
HealthInterval=30s
HealthTimeout=10s
HealthRetries=3
HealthStartPeriod=30s

[Service]
Restart=on-failure
RestartSec=10s
TimeoutStartSec=60s

[Install]
WantedBy=default.target
