# ~/.config/containers/systemd/rag-watcher.container
# Google Drive RAG watcher — polls a Drive folder and ingests documents into Qdrant
# Managed by: systemctl --user [start|stop|restart|status] rag-watcher

[Unit]
Description=Google Drive RAG watcher
After=local-fs.target network-online.target qdrant.service rag-proxy.service
Wants=network-online.target
Requires=qdrant.service rag-proxy.service

[Container]
# Pre-built image with deps + models baked in (see rag-watcher/Containerfile)
# Build: podman build -t localhost/rag-watcher rag-watcher/
Image=localhost/rag-watcher:latest

Volume=%h/git/framework-ai-stack/rag-watcher:/app:ro,z
Volume=%h/git/framework-ai-stack/rag-proxy/docstore.py:/app/docstore.py:ro,z
Volume=%h/.config/ramalama/gdrive-sa.json:/run/secrets/gdrive-sa.json:ro,z
Volume=rag-staging:/staging:Z

EnvironmentFile=%h/.config/llm-stack/env
Environment=GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gdrive-sa.json
Environment=STAGING_DIR=/staging
Environment=QDRANT_URL=http://host.containers.internal:6333
Environment=QDRANT_COLLECTION=documents
Environment=EMBED_URL=http://host.containers.internal:8090/v1/embeddings
Environment=DOCSTORE_BACKEND=postgres
Environment=DOCSTORE_URL=postgresql://litellm:litellm@host.containers.internal:5432/litellm

Network=host

Exec=python3.12 /app/rag-watcher.py

ContainerName=rag-watcher

[Service]
Restart=on-failure
RestartSec=30s
TimeoutStartSec=300s

[Install]
WantedBy=default.target
