# ragstack.env — Postgres credentials and admin tokens for the rag-suite stack
#
# Copy this file to ~/.config/llm-stack/ragstack.env and fill in real values.
# DO NOT commit this file — it contains credentials.
#
# Usage: Each quadlet sources this file via EnvironmentFile=.

# ── Postgres credentials (sclorg image) ─────────────────────────────────────
# Used by: postgres.container (creates the database), all services that connect
POSTGRESQL_USER=litellm
POSTGRESQL_PASSWORD=changeme-use-a-strong-password
POSTGRESQL_DATABASE=litellm

# ── Connection strings ──────────────────────────────────────────────────────
# Full DATABASE_URL for services connecting to Postgres from the host
DATABASE_URL=postgresql://litellm:changeme-use-a-strong-password@localhost:5432/litellm

# DOCSTORE_URL for containers connecting via host.containers.internal
DOCSTORE_URL=postgresql://litellm:changeme-use-a-strong-password@host.containers.internal:5432/litellm

# ── Admin tokens ────────────────────────────────────────────────────────────
# Set real tokens before exposing services to a network
RAGPIPE_ADMIN_TOKEN=changeme-use-a-random-token
RAGSTUFFER_ADMIN_TOKEN=changeme-use-a-random-token
