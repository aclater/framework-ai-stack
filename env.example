# ~/.config/llm-stack/env
# Copy this file: mkdir -p ~/.config/llm-stack && cp env.example ~/.config/llm-stack/env

# ── GPU ─────────────────────────────────────────────────────────────────────
# AI Max+ 395 — gfx1151 (RDNA 3.5 iGPU)
# Remove HSA_OVERRIDE_GFX_VERSION once ROCm ships native gfx1151 support.
HSA_OVERRIDE_GFX_VERSION=11.5.1
LLAMA_HIP_UMA=1

# ── LiteLLM ─────────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-llm-stack-local

# ── Postgres (used by LiteLLM) ──────────────────────────────────────────────
DATABASE_URL=postgresql://litellm:litellm@localhost:5432/litellm

# ── Open WebUI ───────────────────────────────────────────────────────────────
WEBUI_SECRET_KEY=change-me-before-exposing-to-network
# Open WebUI talks to LiteLLM as its OpenAI backend
OPENAI_API_KEY=sk-llm-stack-local

# ── Anthropic (optional — for Claude passthrough, used directly by Claude Code)
# Do NOT pass this through LiteLLM — keep it in Claude Code's own env.
# ANTHROPIC_API_KEY=
