# RAG proxy — pre-built image with all Python dependencies
# Base: UBI9 Python 3.11 (same digest as quadlet for consistency)
FROM registry.access.redhat.com/ubi9/python-311@sha256:8fb94e142e1093b82ca64b334264a5da8e874567d64ce4b6d614f86da3e38813

# Install dependencies at build time (not runtime)
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt && \
    rm /tmp/requirements.txt

# Pre-download models so first request isn't slow
RUN python3 -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('sentence-transformers/all-mpnet-base-v2')" && \
    python3 -c "from sentence_transformers import CrossEncoder; CrossEncoder('cross-encoder/ms-marco-MiniLM-L-6-v2')"

# App code is mounted as a volume at runtime for dev workflow
WORKDIR /app
USER 1001
EXPOSE 8090
CMD ["python3", "/app/rag-proxy.py"]
