# RAG watcher — pre-built image with system packages and Python dependencies
# Base: UBI10 (matches current quadlet)
# No embedding model — delegates to rag-proxy via /v1/embeddings
FROM registry.access.redhat.com/ubi10:latest

# Install system packages at build time (not runtime)
RUN dnf install -y -q python3.12 python3.12-pip git-core && \
    dnf clean all && \
    rm -rf /var/cache/dnf

# Install Python dependencies at build time
COPY requirements.txt /tmp/requirements.txt
RUN pip3.12 install --no-cache-dir -r /tmp/requirements.txt

# App code is mounted as a volume at runtime for dev workflow
WORKDIR /app
CMD ["python3.12", "/app/rag-watcher.py"]
